{
    "name": "@trezor/evolu-relay",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "start": "printf \"\\e[31mDEPRECATION WARNING: This is only for Backward Compatibility.\n\\e[0m\" && node dist/src/index.js",
        "start-quota-manager": "node dist/src/quotaManager/index.js",
        "start-evolu-relay": "node dist/src/evoluRelay/index.js",
        "dev": "tsx watch src/index.ts",
        "test": "vitest",
        "format": "prettier --write src",
        "format:check": "prettier --check src",
        "type-check": "tsc --build tsconfig.json",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "dependencies": {
        "@evolu/common": "8.0.0-next.1",
        "@evolu/nodejs": "3.0.0-next.1",
        "@trezor/device-authenticity": "^1.1.1",
        "@trezor/protobuf": "1.5.1",
        "dotenv": "^17.2.4",
        "fastify": "^5.7.4",
        "kysely": "^0.28.11",
        "pg": "^8.18.0",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@jest/globals": "^30.2.0",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^25.2.3",
        "@types/pg": "^8",
        "better-sqlite3": "^12.6.2",
        "eslint": "^9.39.2",
        "eslint-plugin-import": "^2.32.0",
        "globals": "^16.4.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.55.0",
        "vitest": "^4.0.18"
    },
    "packageManager": "yarn@4.12.0"
}
