{
    "name": "@trezor/evolu-relay",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "start": "printf \"\\e[31mDEPRECATION WARNING: This is only for Backward Compatibility.\n\\e[0m\" && node dist/src/index.js",
        "start-quota-manager": "node dist/src/quotaManager/index.js",
        "start-evolu-relay": "node dist/src/evoluRelay/index.js",
        "start-metrics": "node dist/src/metrics/index.js",
        "dev": "tsx watch src/index.ts",
        "test": "vitest",
        "format": "prettier --write src",
        "format:check": "prettier --check src",
        "type-check": "tsc --build tsconfig.json",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "dependencies": {
        "@evolu/common": "8.0.0-next.5",
        "@evolu/nodejs": "3.0.0-next.3",
        "@trezor/device-authenticity": "^1.1.2",
        "@trezor/protobuf": "1.5.3",
        "dotenv": "^17.4.2",
        "fastify": "^5.8.5",
        "kysely": "^0.29.2",
        "pg": "^8.21.0",
        "prom-client": "^15.1.3",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@jest/globals": "^30.4.1",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^24.13.2",
        "@types/pg": "^8.20.0",
        "better-sqlite3": "^12.11.1",
        "eslint": "^9.39.4",
        "eslint-plugin-import": "^2.32.0",
        "globals": "^17.6.0",
        "prettier": "^3.8.4",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1",
        "vitest": "^4.1.9"
    },
    "packageManager": "yarn@4.12.0"
}
